<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - Automata</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/Automata.Web.styles.css" asp-append-version="true"/>
</head>
<body class="portal-body">
@{
    var currentPage = ViewContext.RouteData.Values["page"]?.ToString() ?? string.Empty;
    var isMain = string.Equals(currentPage, "/Index", global::System.StringComparison.OrdinalIgnoreCase);
    var isMonitor = currentPage.StartsWith("/Monitor", global::System.StringComparison.OrdinalIgnoreCase);
    var topPath = ViewData["TopPath"]?.ToString() ?? (isMonitor ? "Главная / Монитор ТА" : "Главная");
}

<header class="portal-topline">
    <div class="portal-logo">Лого</div>
    <div class="portal-user">
        <span class="portal-flag"></span>
        <div class="portal-user-text">
            <span>Автоматов А. А.</span>
            <span>Администратор</span>
        </div>
        <span>∨</span>
    </div>
</header>

<div class="portal-shell">
    <aside class="portal-sidebar">
        <div class="portal-side-head">
            <div class="portal-side-title">Навигация</div>
            <div class="portal-side-burger">☰</div>
        </div>
        <nav class="portal-nav">
            <a asp-page="/Index" class="portal-nav-link @(isMain ? "active" : string.Empty)">Главная</a>
            <a asp-page="/Monitor/Index" class="portal-nav-link @(isMonitor ? "active" : string.Empty)">Монитор ТА</a>
            <span class="portal-nav-link disabled">Детальные отчеты</span>
            <span class="portal-nav-link disabled">Учет ТМЦ</span>
            <span class="portal-nav-group">Администрирование</span>
            <span class="portal-nav-sub">Торговые автоматы</span>
            <span class="portal-nav-sub">Компании</span>
        </nav>
    </aside>

    <main class="portal-main">
        <div class="portal-blackbar">
            <div class="portal-company">ООО Торговые Автоматы</div>
            <div class="portal-path">@topPath</div>
        </div>

        <div class="portal-content-wrap">
            @RenderBody()
        </div>
    </main>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
