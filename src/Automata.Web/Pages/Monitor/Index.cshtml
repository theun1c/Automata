@page
@model Automata.Web.Pages.Monitor.IndexModel
@{
    ViewData["Title"] = "Монитор ТА";
    ViewData["TopPath"] = "Монитор ТА";
}

<section class="monitor-panel">
    <!-- Заголовок экрана -->
    <div class="monitor-header">
        <h1>Монитор торговых автоматов</h1>
        <div class="monitor-subtitle">Всего в выборке: @Model.Rows.Count</div>
    </div>

    <!-- Фильтры, поиск и действия -->
    <form method="get" class="monitor-filters-stack">
        <div class="monitor-filters-top">
            <div class="monitor-filter-col">
                <div class="monitor-filter-title">Общее состояние</div>
                <div class="monitor-state-line">
                    <span class="monitor-state-dot working"></span>
                    <span class="monitor-state-dot stopped"></span>
                    <span class="monitor-state-dot service"></span>
                    <select name="StatusId" class="monitor-input monitor-status-select">
                        <option value="">Все статусы</option>
                        @foreach (var status in Model.Statuses)
                        {
                            if (Model.StatusId == status.Id)
                            {
                                <option value="@status.Id" selected>@status.Name</option>
                            }
                            else
                            {
                                <option value="@status.Id">@status.Name</option>
                            }
                        }
                    </select>
                </div>
            </div>

            <div class="monitor-filter-col">
                <div class="monitor-filter-title">Подключение</div>
                <div class="monitor-static-box">4G / GSM / Wi-Fi / Ethernet</div>
            </div>

            <div class="monitor-filter-col">
                <div class="monitor-filter-title">Дополнительные статусы</div>
                <div class="monitor-static-box">Нет бумаги · Дверь · Офлайн · Норма</div>
            </div>

            <div class="monitor-filter-col">
                <div class="monitor-filter-title">Сортировка</div>
                <select name="SortBy" class="monitor-input">
                    @foreach (var option in Model.SortOptions)
                    {
                        if (Model.SortBy == option.Value)
                        {
                            <option value="@option.Value" selected>@option.Label</option>
                        }
                        else
                        {
                            <option value="@option.Value">@option.Label</option>
                        }
                    }
                </select>
            </div>
        </div>

        <div class="monitor-filters-bottom">
            <button type="submit" class="monitor-btn primary">Применить</button>
            <a asp-page="/Monitor/Index" class="monitor-btn text-decoration-none text-dark">Очистить</a>
            <button type="submit" class="monitor-btn">Обновить</button>
            <a asp-page="/Monitor/Index"
               asp-page-handler="ExportCsv"
               asp-route-Search="@Model.Search"
               asp-route-StatusId="@Model.StatusId"
               asp-route-SortBy="@Model.SortBy"
               class="monitor-btn text-decoration-none text-dark">Экспорт CSV</a>

            <input name="Search"
                   value="@Model.Search"
                   class="monitor-input monitor-search-input"
                   placeholder="Поиск по названию автомата и локации"/>
        </div>
    </form>

    <!-- Подсказки и сообщения -->
    <div class="monitor-hints">
        <div>Поиск и фильтры в стиле desktop-модуля «Монитор ТА».</div>
        <div>Обновлено: @Model.LastUpdatedText</div>
        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
        {
            <div class="monitor-error">@Model.ErrorMessage</div>
        }
    </div>

    @if (!Model.HasRows)
    {
        <div class="monitor-empty-state">
            Нет автоматов по текущему фильтру.
        </div>
    }
    else
    {
        <!-- Основная таблица мониторинга -->
        <div class="monitor-table-wrap">
            <table class="monitor-table">
                <thead>
                <tr>
                    <th>#</th>
                    <th>Торговый автомат</th>
                    <th>Связь</th>
                    <th>Загрузка</th>
                    <th>Денежные средства</th>
                    <th>События</th>
                    <th>Оборудование</th>
                    <th>Информация</th>
                    <th>Доп.</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var row in Model.Rows)
                {
                    <tr class="@(row.IsAttentionRequired ? "attention" : row.IsRefillRecommended ? "refill" : string.Empty)">
                        <td>@row.Number</td>
                        <td>
                            <div class="machine-main">@row.MachineName</div>
                            <div class="machine-sub">@row.Location</div>
                            <div class="machine-model">@row.ModelDisplayName</div>
                        </td>
                        <td>
                            <div class="status-badge @row.StatusKind">@row.StatusText</div>
                            <div>@row.ConnectionText</div>
                        </td>
                        <td>
                            <div>@row.LoadOverallText</div>
                            <div class="muted">@row.LoadMinText</div>
                        </td>
                        <td>
                            <div>@row.MoneyLine1</div>
                            <div>@row.MoneyLine2</div>
                            <div class="muted">@row.MoneyLine3</div>
                        </td>
                        <td>
                            <div>@row.EventsLine1</div>
                            <div class="muted">@row.EventsLine2</div>
                        </td>
                        <td>@row.EquipmentText</td>
                        <td>@row.InformationText</td>
                        <td>
                            <div>@row.ExtraText</div>
                            <div class="monitor-attention @(row.IsAttentionRequired ? "bad" : row.IsRefillRecommended ? "warn" : "ok")">
                                @(row.IsAttentionRequired ? "Требуется" : row.IsRefillRecommended ? "Пополнить" : "Норма")
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }

    <!-- Нижняя сводка -->
    <div class="monitor-footline">
        <span>Итого автоматов: <b>@Model.Summary.TotalMachines</b></span>
        <span>Рабочие: <b class="ok">@Model.Summary.WorkingMachines</b></span>
        <span>Нерабочие: <b class="bad">@Model.Summary.NotWorkingMachines</b></span>
        <span>Требуют внимания: <b class="bad">@Model.Summary.AttentionRequiredMachines</b></span>
        <span>Денег в автоматах: <b class="money">@Model.Summary.TotalIncome.ToString("N2") ₽</b></span>
    </div>
</section>
