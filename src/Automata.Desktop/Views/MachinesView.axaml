<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Automata.Desktop.ViewModels"
             x:Class="Automata.Desktop.Views.MachinesView"
             x:DataType="vm:MachinesViewModel"
             x:CompileBindings="False"
             x:Name="Root"
             mc:Ignorable="d">

    <Grid RowDefinitions="Auto,Auto,Auto,*,Auto" RowSpacing="8">
        <!-- Заголовок экрана -->
        <StackPanel Spacing="2" Margin="2,0,2,4">
            <TextBlock Text="Торговые автоматы" FontSize="20" FontWeight="SemiBold" Foreground="#2A8FC7"/>
            <TextBlock Text="{Binding RecordsCounterText, StringFormat=Всего найдено: {0}}" FontSize="12" Foreground="#4B5563"/>
        </StackPanel>

        <!-- Панель фильтров и действий -->
        <Border Grid.Row="1" BorderBrush="#D7D7D7" BorderThickness="1" Background="#F6F6F6" Padding="10">
            <Grid ColumnDefinitions="260,210,210,Auto,Auto,Auto,Auto,*,Auto" ColumnSpacing="8" VerticalAlignment="Center">
                <TextBox Watermark="Поиск по названию и локации"
                         Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding Statuses}"
                          SelectedItem="{Binding SelectedStatus, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <ComboBox Grid.Column="2"
                          ItemsSource="{Binding SortOptions}"
                          SelectedItem="{Binding SelectedSort, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <Button Grid.Column="3" Content="+ Создать" Width="96" Command="{Binding OpenCreateMachineFormCommand}"/>
                <Button Grid.Column="4" Content="Редактировать" Width="112" Command="{Binding OpenEditMachineFormCommand}"/>
                <Button Grid.Column="5" Content="Удалить" Width="96" Command="{Binding DeleteSelectedMachineCommand}"/>
                <Button Grid.Column="6" Content="Сбросить все" Command="{Binding ResetFilterCommand}" Width="114"/>

                <Button Grid.Column="7"
                        Content="Обновить"
                        Command="{Binding RefreshMachinesCommand}"
                        Width="96"
                        HorizontalAlignment="Right"
                        Margin="0,0,6,0"/>

                <Button Grid.Column="8"
                        Content="Открыть карточку"
                        Command="{Binding OpenSelectedMachineCommand}"
                        Width="168"
                        Padding="12,6"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        HorizontalAlignment="Right"
                        Margin="0,0,6,0"/>
            </Grid>
        </Border>

        <!-- Служебные подсказки и сообщения -->
        <StackPanel Grid.Row="2" Spacing="4">
            <TextBlock Text="Поиск и фильтры применяются автоматически"
                       Foreground="#4B5563"
                       FontSize="12"/>
            <TextBlock Text="{Binding ModeHint}" Foreground="#4B5563" FontSize="12"/>
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="#B42318"
                       FontSize="12"/>
            <TextBlock Text="{Binding ActionMessage}" Foreground="#2A8FC7" FontSize="12"/>
        </StackPanel>

        <!-- Основная таблица торговых автоматов -->
        <Border Grid.Row="3" BorderBrush="#CFCFCF" BorderThickness="1" Background="#FFFFFF">
            <Grid RowDefinitions="Auto,*">
                <Border Background="#EFEFEF" BorderBrush="#D4D4D4" BorderThickness="0,0,0,1" Padding="8">
                    <Grid ColumnDefinitions="240,260,180,130,120,120,130" ColumnSpacing="8">
                        <TextBlock Text="Название автомата" FontWeight="Bold"/>
                        <TextBlock Grid.Column="1" Text="Локация" FontWeight="Bold"/>
                        <TextBlock Grid.Column="2" Text="Модель" FontWeight="Bold"/>
                        <TextBlock Grid.Column="3" Text="Статус" FontWeight="Bold"/>
                        <TextBlock Grid.Column="4" Text="Установлен" FontWeight="Bold"/>
                        <TextBlock Grid.Column="5" Text="Последний сервис" FontWeight="Bold"/>
                        <TextBlock Grid.Column="6" Text="Доход" FontWeight="Bold" HorizontalAlignment="Right"/>
                    </Grid>
                </Border>

                <ListBox Grid.Row="1"
                         ItemsSource="{Binding Machines}"
                         SelectedItem="{Binding SelectedMachine, Mode=TwoWay}"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#E1E1E1" BorderThickness="0,0,0,1" Padding="8">
                                <Grid ColumnDefinitions="240,260,180,130,120,120,130" ColumnSpacing="8">
                                    <TextBlock Text="{Binding Name}" TextWrapping="Wrap"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Location}" TextWrapping="Wrap"/>
                                    <TextBlock Grid.Column="2" Text="{Binding ModelDisplayName}" TextWrapping="Wrap"/>
                                    <TextBlock Grid.Column="3" Text="{Binding StatusName}"/>
                                    <TextBlock Grid.Column="4" Text="{Binding InstalledAt}"/>
                                    <TextBlock Grid.Column="5" Text="{Binding LastServiceAt}"/>
                                    <TextBlock Grid.Column="6"
                                               Text="{Binding TotalIncome, StringFormat='{}{0:N2} ₽'}"
                                               HorizontalAlignment="Right"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- Нижняя строка статуса выбранной записи и индикатора загрузки -->
        <Grid Grid.Row="4" ColumnDefinitions="*,Auto">
            <TextBlock Text="{Binding SelectedMachine.Name, StringFormat=Выбран автомат: {0}}"
                       Foreground="#4B5563"
                       VerticalAlignment="Center"/>
            <TextBlock Grid.Column="1"
                       Text="{Binding IsLoading, StringFormat=Загрузка: {0}}"
                       Foreground="#4B5563"
                       VerticalAlignment="Center"/>
        </Grid>

        <!-- Модальное окно карточки автомата -->
        <Border Grid.RowSpan="5"
                IsVisible="{Binding IsEditorOpen}"
                Background="#70000000">
            <Border Width="1320"
                    MaxHeight="860"
                    BorderBrush="#CBD5E1"
                    BorderThickness="1"
                    Background="#FFFFFF"
                    CornerRadius="10"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <Grid RowDefinitions="Auto,*,Auto">
                    <Border BorderBrush="#2AA4DE" BorderThickness="0,3,0,1" Background="#F7F7F7" Padding="12,10">
                        <TextBlock Text="{Binding EditorTitle}" FontSize="20" FontWeight="SemiBold" Foreground="#2A8FC7"/>
                    </Border>

                    <!-- Секции формы создания/редактирования -->
                    <ScrollViewer Grid.Row="1" Margin="14,12,14,0">
                        <Grid ColumnDefinitions="1*,1*,1*"
                              RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                              ColumnSpacing="12"
                              RowSpacing="10">
                            <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4">
                                <TextBlock Text="Название ТА *"/>
                                <TextBox Text="{Binding EditForm.MachineName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4">
                                <TextBlock Text="Производитель ТА *"/>
                                <ComboBox ItemsSource="{Binding MainBrands}"
                                          SelectedItem="{Binding SelectedMainBrand, Mode=TwoWay}"/>
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="2" Spacing="4">
                                <TextBlock Text="Модель ТА *"/>
                                <ComboBox ItemsSource="{Binding MainModels}"
                                          SelectedItem="{Binding SelectedMainModel, Mode=TwoWay}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding ModelName}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="0" Spacing="4">
                                <TextBlock Text="Режим работы *"/>
                                <ComboBox ItemsSource="{Binding OperatingModes}"
                                          SelectedItem="{Binding EditForm.SelectedOperatingMode, Mode=TwoWay}"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="1" Spacing="4">
                                <TextBlock Text="Производитель ТА (Slave)"/>
                                <ComboBox ItemsSource="{Binding SlaveBrands}"
                                          SelectedItem="{Binding SelectedSlaveBrand, Mode=TwoWay}"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="2" Spacing="4">
                                <TextBlock Text="Модель ТА (Slave)"/>
                                <ComboBox ItemsSource="{Binding SlaveModels}"
                                          SelectedItem="{Binding SelectedSlaveModel, Mode=TwoWay}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding ModelName}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.Column="0" Spacing="4">
                                <TextBlock Text="Адрес *"/>
                                <TextBox Text="{Binding EditForm.Address, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="1" Spacing="4">
                                <TextBlock Text="Место *"/>
                                <TextBox Text="{Binding EditForm.Place, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="2" Spacing="4">
                                <TextBlock Text="Координаты"/>
                                <TextBox Text="{Binding EditForm.Coordinates, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="3" Grid.Column="0" Spacing="4">
                                <TextBlock Text="Номер автомата *"/>
                                <TextBox Text="{Binding EditForm.MachineNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Row="3" Grid.Column="1" Spacing="4">
                                <TextBlock Text="Время работы (формат: 08:00-22:00)"/>
                                <TextBox Text="{Binding EditForm.WorkingHours, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Row="3" Grid.Column="2" Spacing="4">
                                <TextBlock Text="Часовой пояс *"/>
                                <ComboBox ItemsSource="{Binding TimeZones}"
                                          SelectedItem="{Binding EditForm.SelectedTimeZone, Mode=TwoWay}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="4" Grid.Column="0" Spacing="4">
                                <TextBlock Text="Товарная матрица"/>
                                <ComboBox ItemsSource="{Binding ProductMatrices}"
                                          SelectedItem="{Binding EditForm.SelectedProductMatrix, Mode=TwoWay}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Grid.Row="4" Grid.Column="1" Spacing="4">
                                <TextBlock Text="Шаблон крит. значений"/>
                                <ComboBox ItemsSource="{Binding CriticalTemplates}"
                                          SelectedItem="{Binding EditForm.SelectedCriticalTemplate, Mode=TwoWay}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Grid.Row="4" Grid.Column="2" Spacing="4">
                                <TextBlock Text="Шаблон уведомлений"/>
                                <ComboBox ItemsSource="{Binding NotificationTemplates}"
                                          SelectedItem="{Binding EditForm.SelectedNotificationTemplate, Mode=TwoWay}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Grid.Row="5" Grid.Column="0" Spacing="4">
                                <TextBlock Text="Клиент"/>
                                <TextBox Text="{Binding EditForm.ClientName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Row="5" Grid.Column="1" Spacing="4">
                                <TextBlock Text="Менеджер"/>
                                <ComboBox ItemsSource="{Binding ManagerUsers}"
                                          SelectedItem="{Binding EditForm.SelectedManager, Mode=TwoWay}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DisplayName}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Grid.Row="5" Grid.Column="2" Spacing="4">
                                <TextBlock Text="Инженер"/>
                                <ComboBox ItemsSource="{Binding EngineerUsers}"
                                          SelectedItem="{Binding EditForm.SelectedEngineer, Mode=TwoWay}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DisplayName}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Grid.Row="6" Grid.Column="0" Spacing="4">
                                <TextBlock Text="Техник-оператор"/>
                                <ComboBox ItemsSource="{Binding TechnicianUsers}"
                                          SelectedItem="{Binding EditForm.SelectedTechnicianOperator, Mode=TwoWay}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DisplayName}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Grid.Row="6" Grid.Column="1" Grid.ColumnSpan="2" Spacing="4">
                                <TextBlock Text="Платежные системы *"/>
                                <Border BorderBrush="#D3D3D3" BorderThickness="1" Background="#FFFFFF" Padding="8">
                                    <WrapPanel>
                                        <CheckBox Content="Монетопр." IsChecked="{Binding EditForm.SupportsCoinAcceptor}" Margin="0,0,14,0"/>
                                        <CheckBox Content="Купюропр." IsChecked="{Binding EditForm.SupportsBillAcceptor}" Margin="0,0,14,0"/>
                                        <CheckBox Content="Модуль б/н опл." IsChecked="{Binding EditForm.SupportsCashlessModule}" Margin="0,0,14,0"/>
                                        <CheckBox Content="QR-платежи" IsChecked="{Binding EditForm.SupportsQrPayments}"/>
                                    </WrapPanel>
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Row="7" Grid.Column="0" Spacing="4">
                                <TextBlock Text="RFID карты обслуживания"/>
                                <TextBox Text="{Binding EditForm.ServiceRfidCards, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Row="7" Grid.Column="1" Spacing="4">
                                <TextBlock Text="RFID карты инкассации"/>
                                <TextBox Text="{Binding EditForm.CollectionRfidCards, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Row="7" Grid.Column="2" Spacing="4">
                                <TextBlock Text="RFID карты загрузки"/>
                                <TextBox Text="{Binding EditForm.LoadingRfidCards, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="8" Grid.Column="0" Spacing="4">
                                <TextBlock Text="Id кассы Kit Online (только в случае жесткой привязки)" TextWrapping="Wrap"/>
                                <TextBox Text="{Binding EditForm.KitOnlineCashboxId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Row="8" Grid.Column="1" Spacing="4">
                                <TextBlock Text="Приоритет обслуживания *"/>
                                <ComboBox ItemsSource="{Binding ServicePriorities}"
                                          SelectedItem="{Binding EditForm.SelectedServicePriority, Mode=TwoWay}"/>
                            </StackPanel>
                            <StackPanel Grid.Row="8" Grid.Column="2" Spacing="4">
                                <TextBlock Text="Модем *"/>
                                <ComboBox ItemsSource="{Binding Modems}"
                                          SelectedItem="{Binding EditForm.SelectedModem, Mode=TwoWay}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Grid.Row="9" Grid.Column="0" Grid.ColumnSpan="3" Spacing="4">
                                <TextBlock Text="Примечания"/>
                                <TextBox Text="{Binding EditForm.Notes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True"
                                         Height="72"
                                         TextWrapping="Wrap"/>
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>

                    <Border Grid.Row="2" Background="#EFEFEF" BorderBrush="#D3D3D3" BorderThickness="0,1,0,0" Padding="10">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="Сохранить"
                                    Width="120"
                                    Command="{Binding SaveMachineFormCommand}"
                                    Background="#2E90C9"
                                    Foreground="#FFFFFF"/>
                            <Button Content="Отмена" Width="120" Command="{Binding CancelMachineFormCommand}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Border>
    </Grid>
</UserControl>
