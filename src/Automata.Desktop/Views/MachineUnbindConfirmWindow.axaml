<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:Automata.Desktop.ViewModels"
        x:Class="Automata.Desktop.Views.MachineUnbindConfirmWindow"
        x:DataType="vm:MachinesViewModel"
        Width="540"
        Height="240"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Title="Подтверждение отвязки модема">

    <Border Padding="16" Background="#FFFFFF" BorderBrush="#D0D0D0" BorderThickness="1">
        <StackPanel Spacing="10">
            <TextBlock Text="Подтверждение отвязки модема" FontSize="18" FontWeight="SemiBold"/>
            <TextBlock Text="{Binding SelectedMachine.Name, StringFormat=Отвязать модем у ТА «{0}»? После отвязки отображается -1.}" TextWrapping="Wrap"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                <Button Content="Отвязать" Width="110" Command="{Binding ConfirmUnbindModemCommand}"/>
                <Button Content="Отмена" Width="110" Command="{Binding CancelUnbindModemCommand}"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
