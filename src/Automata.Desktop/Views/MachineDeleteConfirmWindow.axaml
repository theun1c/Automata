<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:Automata.Desktop.ViewModels"
        x:Class="Automata.Desktop.Views.MachineDeleteConfirmWindow"
        x:DataType="vm:MachinesViewModel"
        Width="500"
        Height="220"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Title="Подтверждение удаления">

    <Border Padding="16" Background="#FFFFFF" BorderBrush="#D0D0D0" BorderThickness="1">
        <StackPanel Spacing="10">
            <TextBlock Text="Подтверждение удаления" FontSize="18" FontWeight="SemiBold"/>
            <TextBlock Text="{Binding SelectedMachine.Name, StringFormat=Удалить ТА «{0}»?}" TextWrapping="Wrap"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                <Button Content="Удалить" Width="110" Command="{Binding ConfirmDeleteMachineCommand}"/>
                <Button Content="Отмена" Width="110" Command="{Binding CancelDeleteMachineCommand}"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
