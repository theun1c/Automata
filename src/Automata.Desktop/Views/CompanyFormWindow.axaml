<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:Automata.Desktop.ViewModels"
        x:Class="Automata.Desktop.Views.CompanyFormWindow"
        x:DataType="vm:CompaniesViewModel"
        Width="1320"
        Height="440"
        MinWidth="980"
        MinHeight="360"
        WindowStartupLocation="CenterOwner"
        Title="Компания">

    <Border Background="#F2F2F2" BorderBrush="#CCCCCC" BorderThickness="1">
        <Grid RowDefinitions="Auto,*,Auto">
            <Border BorderBrush="#2AA4DE" BorderThickness="0,3,0,1" Background="#F7F7F7" Padding="12,10">
                <TextBlock Text="{Binding CompanyFormTitle}" FontSize="20" FontWeight="SemiBold" Foreground="#2A8FC7"/>
            </Border>

            <Grid Grid.Row="1" Margin="10,10,10,8" ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="12">
                <StackPanel>
                    <TextBlock Text="Вышестоящая компания *"/>
                    <TextBox Text="{Binding CompanyForm.ParentCompany}"/>
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="Название компании *"/>
                    <TextBox Text="{Binding CompanyForm.CompanyName}"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Адрес компании *"/>
                    <TextBox Text="{Binding CompanyForm.CompanyAddress}"/>
                </StackPanel>

                <StackPanel Grid.Row="1">
                    <TextBlock Text="Контакты компании *"/>
                    <TextBox Text="{Binding CompanyForm.CompanyContacts}"/>
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2">
                    <TextBlock Text="Примечания"/>
                    <TextBox Text="{Binding CompanyForm.Notes}" AcceptsReturn="True" Height="80" TextWrapping="Wrap"/>
                </StackPanel>
            </Grid>

            <Border Grid.Row="2" Background="#EFEFEF" BorderBrush="#D3D3D3" BorderThickness="0,1,0,0" Padding="10">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="Сохранить" Width="120" Command="{Binding SaveCompanyFormCommand}" Background="#2E90C9" Foreground="#FFFFFF"/>
                    <Button Content="Отмена" Width="120" Command="{Binding CloseCompanyFormCommand}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
