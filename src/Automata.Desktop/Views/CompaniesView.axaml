<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Automata.Desktop.ViewModels"
             x:Class="Automata.Desktop.Views.CompaniesView"
             x:DataType="vm:CompaniesViewModel"
             x:CompileBindings="False"
             x:Name="Root"
             mc:Ignorable="d">

    <Grid RowDefinitions="Auto,Auto,Auto,*,Auto" RowSpacing="8">
        <!-- Шапка страницы списка компаний -->
        <StackPanel Spacing="2" Margin="2,0,2,4">
            <TextBlock Text="Список компаний" FontSize="20" FontWeight="SemiBold" Foreground="#2A8FC7"/>
            <TextBlock Text="{Binding RecordsCounterText, StringFormat=Всего найдено {0} шт.}" FontSize="12" Foreground="#4B5563"/>
        </StackPanel>

        <!-- Панель фильтрации и основных действий -->
        <Border Grid.Row="1" BorderBrush="#D7D7D7" BorderThickness="1" Background="#F6F6F6" Padding="10">
            <Grid ColumnDefinitions="Auto,96,Auto,20,360,*,Auto,Auto,Auto,Auto" ColumnSpacing="8" VerticalAlignment="Center">
                <TextBlock Text="Показать" VerticalAlignment="Center" FontSize="14"/>

                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding PageSizes}"
                          SelectedItem="{Binding SelectedPageSize, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <TextBlock Grid.Column="2" Text="записей" VerticalAlignment="Center" FontSize="14"/>

                <TextBox Grid.Column="4"
                         Watermark="Фильтр"
                         Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                <Button Grid.Column="6"
                        Content="+ Добавить"
                        Width="128"
                        Command="{Binding OpenCreateDialogCommand}"/>
                <Button Grid.Column="7"
                        Content="Редактировать"
                        Width="128"
                        Command="{Binding EditSelectedCompanyCommand}"
                        IsEnabled="{Binding CanEditSelectedCompany}"/>
                <Button Grid.Column="8"
                        Content="Удалить"
                        Width="96"
                        Command="{Binding DeleteSelectedCompanyCommand}"
                        IsEnabled="{Binding CanDeleteSelectedCompany}"/>
                <StackPanel Grid.Column="9" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                    <Button Content="Обновить" Width="96" Command="{Binding RefreshCommand}"/>
                    <Button Content="Экспорт" Width="96" Command="{Binding ExportCsvCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Строка служебных сообщений -->
        <StackPanel Grid.Row="2" Spacing="4">
            <TextBlock Text="{Binding ErrorMessage}" Foreground="#B42318" FontSize="12"/>
            <TextBlock Text="{Binding ActionMessage}" Foreground="#2A8FC7" FontSize="12"/>
        </StackPanel>

        <!-- Таблица компаний -->
        <Border Grid.Row="3" BorderBrush="#CFCFCF" BorderThickness="1" Background="#FFFFFF">
            <Grid RowDefinitions="Auto,*">
                <Border Background="#EFEFEF" BorderBrush="#D4D4D4" BorderThickness="0,0,0,1" Padding="8">
                    <Grid ColumnDefinitions="220,200,250,220,110,170" ColumnSpacing="8">
                        <TextBlock Text="Название" FontWeight="Bold"/>
                        <TextBlock Grid.Column="1" Text="Вышестоящая" FontWeight="Bold"/>
                        <TextBlock Grid.Column="2" Text="Адрес" FontWeight="Bold"/>
                        <TextBlock Grid.Column="3" Text="Контакты" FontWeight="Bold"/>
                        <TextBlock Grid.Column="4" Text="В работе с" FontWeight="Bold"/>
                        <TextBlock Grid.Column="5" Text="Действия" FontWeight="Bold"/>
                    </Grid>
                </Border>

                <Grid Grid.Row="1">
                    <ListBox ItemsSource="{Binding Companies}"
                             SelectedItem="{Binding SelectedCompany, Mode=TwoWay}"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#E1E1E1" BorderThickness="0,0,0,1" Padding="8">
                                    <Grid ColumnDefinitions="220,200,250,220,110,170" ColumnSpacing="8">
                                        <TextBlock Text="{Binding Name}" TextWrapping="Wrap"/>
                                        <TextBlock Grid.Column="1" Text="{Binding ParentCompanyName}" TextWrapping="Wrap"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Address}" TextWrapping="Wrap"/>
                                        <TextBlock Grid.Column="3" Text="{Binding ContactsDisplay}" TextWrapping="Wrap"/>
                                        <TextBlock Grid.Column="4" Text="{Binding CreatedAt, StringFormat='{}{0:dd.MM.yyyy}'}"/>
                                        <StackPanel Grid.Column="5" Orientation="Horizontal" Spacing="6">
                                            <Button Content="Изменить"
                                                    Width="78"
                                                    Command="{Binding $parent[UserControl].DataContext.EditCompanyFromRowCommand}"
                                                    CommandParameter="{Binding}"/>
                                            <Button Content="Удалить"
                                                    Width="72"
                                                    Command="{Binding $parent[UserControl].DataContext.DeleteCompanyFromRowCommand}"
                                                    CommandParameter="{Binding}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <TextBlock Text="В таблице отсутствуют данные"
                               IsVisible="{Binding HasNoCompanies}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="#4B5563"
                               FontSize="16"/>
                </Grid>
            </Grid>
        </Border>

        <!-- Нижняя строка статуса -->
        <Grid Grid.Row="4" ColumnDefinitions="*,Auto">
            <TextBlock Text="{Binding RecordsCounterText, StringFormat=Записи с 0 до {0} из {0} записей}"
                       Foreground="#4B5563"
                       VerticalAlignment="Center"/>
            <TextBlock Grid.Column="1"
                       Text="{Binding IsLoading, StringFormat=Загрузка: {0}}"
                       Foreground="#4B5563"
                       VerticalAlignment="Center"/>
        </Grid>

        <!-- Модальное окно создания/редактирования компании -->
        <Border Grid.RowSpan="5"
                IsVisible="{Binding IsDialogOpen}"
                Background="#70000000">
            <Border Width="1240"
                    MaxHeight="580"
                    BorderBrush="#CBD5E1"
                    BorderThickness="1"
                    Background="#FFFFFF"
                    CornerRadius="10"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <Grid RowDefinitions="Auto,Auto" RowSpacing="0">
                    <!-- Основные поля формы -->
                    <Border BorderBrush="#E5E7EB" BorderThickness="0,1,0,1" Padding="18,16">
                        <Grid ColumnDefinitions="1*,1*,1*" RowDefinitions="Auto,Auto" ColumnSpacing="22" RowSpacing="14">
                            <StackPanel Grid.Row="0" Grid.Column="0" Spacing="5">
                                <TextBlock Text="Вышестоящая компания *" FontWeight="SemiBold"/>
                                <ComboBox ItemsSource="{Binding ParentCompanies}"
                                          SelectedItem="{Binding Dialog.SelectedParentCompany, Mode=TwoWay}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="1" Spacing="5">
                                <TextBlock Text="Название компании *" FontWeight="SemiBold"/>
                                <TextBox Text="{Binding Dialog.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="2" Spacing="5">
                                <TextBlock Text="Адрес компании *" FontWeight="SemiBold"/>
                                <TextBox Text="{Binding Dialog.Address, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="0" Spacing="5">
                                <TextBlock Text="Контакты компании *" FontWeight="SemiBold"/>
                                <TextBox Text="{Binding Dialog.Contacts, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Spacing="5">
                                <TextBlock Text="Примечания" FontWeight="SemiBold"/>
                                <TextBox Text="{Binding Dialog.Notes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         Height="78"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Нижняя панель действий модального окна -->
                    <Border Grid.Row="1" Background="#F8F8F8" Padding="18,12" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="{Binding DialogErrorMessage}" Foreground="#B42318" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                <Button Content="{Binding DialogSubmitButtonText}"
                                        Width="132"
                                        Command="{Binding SaveDialogCommand}"/>
                                <Button Content="Отменить"
                                        Width="132"
                                        Command="{Binding CloseDialogCommand}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Border>
    </Grid>
</UserControl>
