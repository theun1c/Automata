<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:Automata.Desktop.ViewModels"
        x:Class="Automata.Desktop.Views.MachineFormWindow"
        x:DataType="vm:MachinesViewModel"
        x:CompileBindings="False"
        Width="1360"
        Height="900"
        MinWidth="1120"
        MinHeight="760"
        CanResize="True"
        WindowStartupLocation="CenterOwner"
        SystemDecorations="Full"
        Title="Торговый автомат">

    <Border Background="#F2F2F2" BorderBrush="#CCCCCC" BorderThickness="1">
        <Grid RowDefinitions="Auto,*,Auto">
            <Border BorderBrush="#2AA4DE" BorderThickness="0,3,0,1" Background="#F7F7F7" Padding="12,10">
                <TextBlock Text="{Binding MachineFormTitle}" FontSize="20" FontWeight="SemiBold" Foreground="#2A8FC7"/>
            </Border>

            <ScrollViewer Grid.Row="1" Margin="10,10,10,0">
                <StackPanel Spacing="10">
                    <WrapPanel ItemWidth="430" ItemHeight="84">
                        <StackPanel Width="418"><TextBlock Text="Название ТА *"/><TextBox Text="{Binding MachineForm.MachineName}"/></StackPanel>
                        <StackPanel Width="418"><TextBlock Text="Производитель ТА *"/><TextBox Text="{Binding MachineForm.Manufacturer}"/></StackPanel>
                        <StackPanel Width="418"><TextBlock Text="Модель ТА *"/><TextBox Text="{Binding MachineForm.Model}"/></StackPanel>

                        <StackPanel Width="418"><TextBlock Text="Режим работы *"/><TextBox Text="{Binding MachineForm.WorkMode}"/></StackPanel>
                        <StackPanel Width="418"><TextBlock Text="Производитель ТА (Slave) *"/><TextBox Text="{Binding MachineForm.SlaveManufacturer}"/></StackPanel>
                        <StackPanel Width="418"><TextBlock Text="Модель ТА (Slave) *"/><TextBox Text="{Binding MachineForm.SlaveModel}"/></StackPanel>

                        <StackPanel Width="418"><TextBlock Text="Адрес *"/><TextBox Text="{Binding MachineForm.Address}"/></StackPanel>
                        <StackPanel Width="418"><TextBlock Text="Место *"/><TextBox Text="{Binding MachineForm.Place}"/></StackPanel>
                        <StackPanel Width="418"><TextBlock Text="Координаты"/><TextBox Text="{Binding MachineForm.Coordinates}"/></StackPanel>

                        <StackPanel Width="418"><TextBlock Text="Номер автомата *"/><TextBox Text="{Binding MachineForm.MachineNumber}"/></StackPanel>
                        <StackPanel Width="418"><TextBlock Text="Время работы (формат: 08:00-22:00)"/><TextBox Text="{Binding MachineForm.WorkingHours}"/></StackPanel>
                        <StackPanel Width="418"><TextBlock Text="Часовой пояс *"/><TextBox Text="{Binding MachineForm.Timezone}"/></StackPanel>

                        <StackPanel Width="418"><TextBlock Text="Товарная матрица *"/><TextBox Text="{Binding MachineForm.ProductMatrix}"/></StackPanel>
                        <StackPanel Width="418"><TextBlock Text="Шаблон крит. значений"/><TextBox Text="{Binding MachineForm.CriticalTemplate}"/></StackPanel>
                        <StackPanel Width="418"><TextBlock Text="Шаблон уведомлений"/><TextBox Text="{Binding MachineForm.NotificationTemplate}"/></StackPanel>

                        <StackPanel Width="418"><TextBlock Text="Клиент"/><TextBox Text="{Binding MachineForm.Client}"/></StackPanel>
                        <StackPanel Width="418"><TextBlock Text="Менеджер"/><TextBox Text="{Binding MachineForm.Manager}"/></StackPanel>
                        <StackPanel Width="418"><TextBlock Text="Инженер"/><TextBox Text="{Binding MachineForm.Engineer}"/></StackPanel>

                        <StackPanel Width="418"><TextBlock Text="Техник-оператор"/><TextBox Text="{Binding MachineForm.Technician}"/></StackPanel>
                        <StackPanel Width="838">
                            <TextBlock Text="Платежные системы *"/>
                            <Border BorderBrush="#D3D3D3" BorderThickness="1" Background="#FFFFFF" Padding="8">
                                <WrapPanel>
                                    <CheckBox Content="Монетопр." IsChecked="{Binding MachineForm.HasCoinAcceptor}" Margin="0,0,14,0"/>
                                    <CheckBox Content="Купюропр." IsChecked="{Binding MachineForm.HasBillAcceptor}" Margin="0,0,14,0"/>
                                    <CheckBox Content="Модуль б/н опл." IsChecked="{Binding MachineForm.HasCashlessModule}" Margin="0,0,14,0"/>
                                    <CheckBox Content="QR-платежи" IsChecked="{Binding MachineForm.HasQrPayment}"/>
                                </WrapPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel Width="418"><TextBlock Text="RFID карты обслуживания"/><TextBox Text="{Binding MachineForm.ServiceRfidCard}"/></StackPanel>
                        <StackPanel Width="418"><TextBlock Text="RFID карты инкассации"/><TextBox Text="{Binding MachineForm.CollectionRfidCard}"/></StackPanel>
                        <StackPanel Width="418"><TextBlock Text="RFID карты загрузки"/><TextBox Text="{Binding MachineForm.LoadingRfidCard}"/></StackPanel>

                        <StackPanel Width="418"><TextBlock Text="Id кассы Kit Online (только в случае жесткой привязки)"/><TextBox Text="{Binding MachineForm.KitOnlineCashboxId}"/></StackPanel>
                        <StackPanel Width="418"><TextBlock Text="Приоритет обслуживания *"/><TextBox Text="{Binding MachineForm.ServicePriority}"/></StackPanel>
                        <StackPanel Width="418"><TextBlock Text="Модем *"/><TextBox Text="{Binding MachineForm.Modem}"/></StackPanel>
                    </WrapPanel>

                    <StackPanel>
                        <TextBlock Text="Примечания"/>
                        <TextBox Text="{Binding MachineForm.Notes}" AcceptsReturn="True" Height="70" TextWrapping="Wrap"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="2" Background="#EFEFEF" BorderBrush="#D3D3D3" BorderThickness="0,1,0,0" Padding="10">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="Сохранить" Width="120" Command="{Binding SaveMachineFormCommand}" Background="#2E90C9" Foreground="#FFFFFF"/>
                    <Button Content="Отмена" Width="120" Command="{Binding CloseMachineFormCommand}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
