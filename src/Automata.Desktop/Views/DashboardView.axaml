<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Automata.Desktop.ViewModels"
             x:Class="Automata.Desktop.Views.DashboardView"
             x:DataType="vm:DashboardViewModel"
             x:CompileBindings="False"
             mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel Spacing="12">
            <Grid ColumnDefinitions="1.05*,1.05*,1.2*" ColumnSpacing="12">
                <Border BorderBrush="#D3D3D3" BorderThickness="1" Background="#FFFFFF">
                    <Grid RowDefinitions="Auto,*">
                        <Border Background="#F6F6F6" BorderBrush="#DADADA" BorderThickness="0,0,0,1" Padding="10,8">
                            <TextBlock Text="Эффективность сети" FontSize="16" FontWeight="SemiBold"/>
                        </Border>
                        <StackPanel Grid.Row="1" Margin="10,8,10,10" Spacing="8" HorizontalAlignment="Center">
                            <Grid Width="160" Height="96">
                                <Border Width="140" Height="140" CornerRadius="70" BorderBrush="#0AC43B" BorderThickness="26" Background="Transparent" VerticalAlignment="Top" ClipToBounds="True"/>
                            </Grid>
                            <TextBlock Text="{Binding EfficiencyText}" FontSize="24" FontWeight="Bold" Foreground="#0B9A3A" HorizontalAlignment="Center"/>
                            <TextBlock Text="Работающих автоматов - 100%" FontSize="12" Foreground="#4B5563"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Column="1" BorderBrush="#D3D3D3" BorderThickness="1" Background="#FFFFFF">
                    <Grid RowDefinitions="Auto,*">
                        <Border Background="#F6F6F6" BorderBrush="#DADADA" BorderThickness="0,0,0,1" Padding="10,8">
                            <TextBlock Text="Состояние сети" FontSize="16" FontWeight="SemiBold"/>
                        </Border>
                        <Grid Grid.Row="1" Margin="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid Width="160" Height="160" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Ellipse Width="132" Height="132" Stroke="#1DA0DC" StrokeThickness="20"/>
                                <Border Width="78" Height="78" CornerRadius="39" Background="#FFFFFF" BorderBrush="#D1D5DB" BorderThickness="1">
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock Text="Под вопросом" FontSize="11" HorizontalAlignment="Center"/>
                                        <TextBlock Text="9" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                            <ItemsControl Grid.Column="1" ItemsSource="{Binding NetworkStatuses}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnDefinitions="14,*,Auto" Margin="0,6,0,6" ColumnSpacing="8">
                                            <Border Width="10" Height="10" CornerRadius="5" Background="{Binding Color}" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Title}" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="2" Text="{Binding Count}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Column="2" BorderBrush="#D3D3D3" BorderThickness="1" Background="#FFFFFF">
                    <Grid RowDefinitions="Auto,*">
                        <Border Background="#F6F6F6" BorderBrush="#DADADA" BorderThickness="0,0,0,1" Padding="10,8">
                            <TextBlock Text="Сводка" FontSize="16" FontWeight="SemiBold"/>
                        </Border>
                        <ItemsControl Grid.Row="1" Margin="10,8,10,10" ItemsSource="{Binding SummaryCards}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="*,Auto" Margin="0,3,0,3">
                                        <TextBlock Text="{Binding Title}" FontSize="13" Foreground="#374151"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Value}" FontSize="13" FontWeight="SemiBold"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>
            </Grid>

            <Grid ColumnDefinitions="1.9*,1.1*" ColumnSpacing="12">
                <Border BorderBrush="#D3D3D3" BorderThickness="1" Background="#FFFFFF">
                    <Grid RowDefinitions="Auto,Auto,*">
                        <Border Background="#F6F6F6" BorderBrush="#DADADA" BorderThickness="0,0,0,1" Padding="10,8">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Динамика продаж за последние 10 дней" FontSize="16" FontWeight="SemiBold"/>
                                <TextBlock Text="Данные по продажам с 01.03.2026 по 10.03.2026" FontSize="12" Foreground="#6B7280"/>
                            </StackPanel>
                        </Border>

                        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="6" Margin="10,10,10,8">
                            <Button Content="По сумме" Width="110" Command="{Binding ShowAmountCommand}" Background="#1EA7E2" Foreground="#FFFFFF"/>
                            <Button Content="По количеству" Width="120" Command="{Binding ShowQuantityCommand}"/>
                        </StackPanel>

                        <Border Grid.Row="2" Margin="10,0,10,10" BorderBrush="#E2E8F0" BorderThickness="1" Padding="10">
                            <ItemsControl ItemsSource="{Binding SalesDynamics}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="8"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Width="56" Spacing="4" VerticalAlignment="Bottom">
                                            <Border Height="170" Background="#F5F7FA" BorderBrush="#E5E7EB" BorderThickness="1">
                                                <Border Width="54"
                                                        Height="{Binding ColumnHeight}"
                                                        Background="#A8D2EA"
                                                        BorderBrush="#89C1DF"
                                                        BorderThickness="1"
                                                        VerticalAlignment="Bottom"/>
                                            </Border>
                                            <TextBlock Text="{Binding Day}" FontSize="11" HorizontalAlignment="Center"/>
                                            <TextBlock Text="{Binding Value}" FontSize="11" HorizontalAlignment="Center" Foreground="#6B7280"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Column="1" BorderBrush="#D3D3D3" BorderThickness="1" Background="#FFFFFF">
                    <Grid RowDefinitions="Auto,*">
                        <Border Background="#F6F6F6" BorderBrush="#DADADA" BorderThickness="0,0,0,1" Padding="10,8">
                            <TextBlock Text="Новости" FontSize="16" FontWeight="SemiBold"/>
                        </Border>
                        <ItemsControl Grid.Row="1" Margin="10,10,10,6" ItemsSource="{Binding NewsItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="74,*" Margin="0,0,0,10" ColumnSpacing="6">
                                        <TextBlock Text="{Binding Date}" FontSize="12" Foreground="#4B5563"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Title}" TextWrapping="Wrap" FontSize="12"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
