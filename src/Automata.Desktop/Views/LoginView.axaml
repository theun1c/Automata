<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Automata.Desktop.ViewModels"
             x:Class="Automata.Desktop.Views.LoginView"
             x:DataType="vm:LoginViewModel"
             mc:Ignorable="d">

    <!-- Основной контейнер авторизации, выровненный по центру окна -->
    <Grid>
        <Border Width="560"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Padding="24"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="10"
                Background="#FFFFFF">
            <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,*">
                <!-- Заголовок и краткая подсказка по входу -->
                <TextBlock Text="Вход в систему" FontSize="26" FontWeight="Bold" Foreground="#0F172A"/>
                <TextBlock Grid.Row="1"
                           Margin="0,6,0,18"
                           Text="Для пользователей из таблицы users используйте пароль Baklan232!! (если пароль не переопределяли в настройках среды)."
                           Foreground="#64748B"
                           TextWrapping="Wrap"/>

                <!-- Поля логина -->
                <TextBlock Grid.Row="2" Text="Email" FontWeight="SemiBold"/>
                <TextBox Grid.Row="3" Watermark="Введите email" Text="{Binding Email, Mode=TwoWay}"/>

                <TextBlock Grid.Row="4" Margin="0,12,0,0" Text="Пароль" FontWeight="SemiBold"/>
                <Grid Grid.Row="5">
                    <TextBox IsVisible="{Binding ShowPassword}" Watermark="Введите пароль" Text="{Binding Password, Mode=TwoWay}"/>
                    <TextBox IsVisible="{Binding IsPasswordMasked}" Watermark="Введите пароль" Text="{Binding Password, Mode=TwoWay}" PasswordChar="●"/>
                </Grid>

                <CheckBox Grid.Row="6" Margin="0,10,0,0" Content="Показать пароль" IsChecked="{Binding ShowPassword, Mode=TwoWay}"/>

                <!-- Кнопки действий -->
                <StackPanel Grid.Row="7" Orientation="Horizontal" Spacing="12" Margin="0,14,0,0">
                    <Button Content="Вход" Width="160" Command="{Binding SignInCommand}"/>
                    <Button Content="К регистрации" Width="160" Command="{Binding GoToRegistrationCommand}"/>
                </StackPanel>

                <TextBlock Grid.Row="8"
                           Margin="0,10,0,0"
                           Text="{Binding IsLoading, StringFormat=Выполняется вход: {0}}"
                           Foreground="#4B5563"/>

                <!-- Блок ошибки входа -->
                <TextBlock Grid.Row="9"
                           Margin="0,16,0,0"
                           Text="{Binding ErrorText}"
                           Foreground="#B91C1C"
                           TextWrapping="Wrap"
                           IsVisible="{Binding HasError}"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
